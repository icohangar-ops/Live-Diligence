# Live Diligence — environment variables

# Lovable / Supabase (auto-provisioned on Lovable Cloud)
LOVABLE_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Airbyte Agent CLI — primary path for Exa + Stripe (https://docs.airbyte.com/ai-agents/interfaces/cli)
# Set all three for server/CI, or run `airbyte-agent login` locally and set AIRBYTE_USE_CLI=true
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_ORGANIZATION_ID=
AIRBYTE_WORKSPACE=default
AIRBYTE_USE_CLI=false
AIRBYTE_AGENT_BIN=airbyte-agent

# Fallback when Airbyte CLI is unavailable
EXA_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
