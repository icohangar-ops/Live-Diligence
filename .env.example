# ---------------------------------------------------------------------------
# Live-Diligence environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Supabase (server) ---
SUPABASE_PROJECT_ID=
SUPABASE_URL=
# Public anon key (safe to expose to clients, but still rotate if leaked)
SUPABASE_PUBLISHABLE_KEY=
# Service-role key — SECRET, full DB access, server-only. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (client / Vite — exposed to the browser bundle) ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- App ---
# Public base URL of the deployed app, e.g. https://app.example.com
PUBLIC_APP_URL=
# Shared secret authenticating the internal /api/public/run-report call.
# Required — generate a long random value (e.g. `openssl rand -hex 32`).
AGENT_RUNNER_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
# Required to verify webhook signatures. Without it, webhooks are rejected.
STRIPE_WEBHOOK_SECRET=

# --- Agent / data providers ---
LOVABLE_API_KEY=
EXA_API_KEY=

# --- Optional ---
# DATABASE_URL=
