# Live Diligence — environment variables

# Lovable / Supabase (auto-provisioned on Lovable Cloud)
LOVABLE_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Airbyte Agent CLI — Exa web search only (Stripe uses STRIPE_SECRET_KEY directly).
# Run: bash scripts/setup-airbyte-connectors.sh
# Docs: https://docs.airbyte.com/ai-agents/interfaces/cli
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_ORGANIZATION_ID=
AIRBYTE_WORKSPACE=default
AIRBYTE_USE_CLI=true
AIRBYTE_AGENT_BIN=airbyte-agent

# Exa fallback if Airbyte CLI unavailable; Stripe always direct
EXA_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
